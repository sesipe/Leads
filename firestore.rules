rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) ||
        (request.auth.token.email == 'maykon.euro@gmail.com' && request.auth.token.email_verified == true) ||
        (request.auth.token.email == 'tablet.diretoriaeducacao@gmail.com' && request.auth.token.email_verified == true)
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Validation for Lead
    function isValidLead(data) {
      return data.keys().hasAll(['name', 'category', 'email', 'whatsapp', 'schoolId', 'courseId', 'grade', 'createdAt', 'status'])
        && data.keys().size() == 9
        && data.name is string && data.name.size() > 0 && data.name.size() <= 100
        && data.category in ['Pai', 'Mãe', 'Responsável Legal', 'Outro']
        && data.email is string && data.email.size() <= 100 && data.email.matches('.+@.+\\..+')
        && data.whatsapp is string && data.whatsapp.size() >= 10 && data.whatsapp.size() <= 20
        && data.schoolId is string && data.schoolId.size() <= 128
        && data.courseId is string && data.courseId.size() <= 128
        && data.grade is string && data.grade.size() > 0 && data.grade.size() <= 50
        && data.createdAt == request.time
        && data.status == 'Pendente';
    }

    // Schools
    match /schools/{schoolId} {
      allow read: if true; // Publicly readable for the form
      allow write: if isAdmin();
    }

    // Courses
    match /courses/{courseId} {
      allow read: if true; // Publicly readable for the form
      allow write: if isAdmin();
    }

    // Leads
    match /leads/{leadId} {
      allow create: if isValidLead(incoming());
      allow list, get, update, delete: if isAdmin();
    }

    // Admins collection
    match /admins/{adminId} {
      allow read: if isSignedIn() && (request.auth.uid == adminId || isAdmin());
      allow write: if isAdmin(); // Admins can manage other admins
    }

    // Settings
    match /settings/{settingsId} {
      allow read: if true; // Publicly readable to get templates if needed (or maybe just read if admin?)
      // Actually, templates might be needed by the client to show what will be sent, but normally sent by server.
      // Let's keep it restricted to Admin for now.
      allow read, write: if isAdmin();
    }
  }
}
